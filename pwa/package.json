{
  "name": "venezuela-sa-pwa",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "npm run build:mermaid && vite build && npm run build:search",
    "build:mermaid": "node scripts/build-mermaid.js",
    "build:search": "npx pagefind --site build --glob '**/*.html'",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "test": "vitest run",
    "check:bundle": "node scripts/check-bundle-size.js"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/svelte": "^5.0.0",
    "@vite-pwa/sveltekit": "^1.1.0",
    "jsdom": "^26.0.0",
    "pagefind": "^1.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@lucide/svelte": "^0.577.0",
    "@microflash/remark-callout-directives": "^5.0.0",
    "gray-matter": "^4.0.3",
    "mdsvex": "^0.12.7",
    "mode-watcher": "^1.0.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "type": "module"
}
